# Required for live LLM E2E
E2E_LLM_PROVIDER=openrouter
E2E_LLM_API_KEY=your-api-key-here
E2E_LLM_MODEL=arcee-ai/trinity-large-preview:free
# E2E_LLM_MODEL=gpt-4o
# E2E_LLM_MODEL=claude-sonnet-4-20250514

# Optional tuning
E2E_TIMEOUT_MS=30000
E2E_MAX_RETRIES=2

# Optional but recommended by OpenRouter (when E2E_LLM_PROVIDER=openrouter)
E2E_OPENROUTER_SITE_URL=https://your-site.example
E2E_OPENROUTER_APP_NAME=mantle-mcp-e2e

# Optional: enables indexer scenarios (otherwise they are skipped)
E2E_SUBGRAPH_ENDPOINT=https://your-subgraph-endpoint
E2E_SQL_ENDPOINT=https://your-sql-endpoint

# Optional: CoinGecko API key for higher rate limits.
# Two tiers are auto-detected — use ONE of the following env vars:
#
#   COINGECKO_PRO_API_KEY   → paid Pro plan; uses pro-api.coingecko.com + `x-cg-pro-api-key` header
#   COINGECKO_DEMO_API_KEY  → free Demo plan; uses api.coingecko.com + `x-cg-demo-api-key` header
#   COINGECKO_API_KEY       → legacy alias for COINGECKO_DEMO_API_KEY (Demo tier)
#
# If both COINGECKO_PRO_API_KEY and a Demo key are set, the Pro key wins.
# With no key, the free public API is used (~10–30 req/min, subject to throttling).
# Get a key at https://www.coingecko.com/en/api
# COINGECKO_PRO_API_KEY=your-coingecko-pro-api-key-here
# COINGECKO_DEMO_API_KEY=your-coingecko-demo-api-key-here
